{
  "name": "blog",
  "version": "1.0.0",
  "description": "Blog",
  "engines": {
    "node": ">=16.13",
    "pnpm": ">=6.24",
    "preinstall": "npx only-allow pnpm"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "blog:dev": "pnpm run blog:dev --filter \"@dragondyt/blog\"",
    "build-ts": "pnpm run build --filter \"@dragondyt/*\"",
    "build-watch": "pnpm build-watch --parallel --filter \"@dragondyt/*\"",
    "clean-resource": "pnpm run blog:clean --filter \"@dragondyt/blog\" && pnpm run clean --filter \"@dragondyt/*\" --stream",
    "copy-resource": "pnpm run copy --filter \"@dragondyt/*\" --stream ",
    "copy-resource-watch": "pnpm run copy --parallel -- --watch",
    "pro-build": "pnpm install && pnpm clean-resource && pnpm build-ts && pnpm copy-resource && pnpm run blog:build --filter \"@dragondyt/blog\""
  },
  "devDependencies": {
    "@vuedx/typescript-plugin-vue": "^0.7.4",
    "cpx2": "^4.2.0",
    "rimraf": "^3.0.2",
    "typescript": "^4.6.2"
  }
}
