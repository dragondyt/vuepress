{
  "name": "blog",
  "version": "1.0.0",
  "description": "Blog",
  "engines": {
    "node": ">=16.13",
    "pnpm": ">=7.0",
    "preinstall": "npx only-allow pnpm"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "blog:dev": "pnpm run blog:dev --filter \"@dragondyt/blog\"",
    "build-ts": "pnpm run build --filter \"@dragondyt/*\"",
    "build-watch": "pnpm --parallel --filter \"@dragondyt/*\" build-watch ",
    "clean-resource": "pnpm --filter \"@dragondyt/*\" run clean  --stream",
    "copy-resource": "pnpm --filter \"@dragondyt/*\" --stream run copy ",
    "copy-resource-watch": "pnpm --parallel run copy  --watch ",
    "pro-build": "pnpm install && pnpm clean-resource && pnpm build-ts && pnpm copy-resource && pnpm run blog:build --filter \"@dragondyt/blog\""
  },
  "devDependencies": {
    "@vuedx/typescript-plugin-vue": "^0.7.5",
    "cpx2": "^4.2.0",
    "rimraf": "^3.0.2",
    "typescript": "^4.6.4"
  }
}
